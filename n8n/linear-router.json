    {
      "parameters": {
        "jsCode": "// Classify Fire routine response. Returns { outcome } where outcome is 'ok' | 'capped' | 'failed'.\n// Response shape from https://code.claude.com/docs/en/routines#trigger-a-routine is:\n//   { type: 'routine_fire', claude_code_session_id: '...', claude_code_session_url: '...' }\nconst pickInput = $('Pick routine').item.json;\nconst resp = $input.first().json;\nconst status = resp.statusCode || resp.status || 0;\nconst body = resp.body || resp;\n\nlet outcome;\nif (status >= 200 && status < 300) outcome = 'ok';\nelse if (status === 429) outcome = 'capped';\nelse outcome = 'failed';\n\nreturn [{\n  json: {\n    ...pickInput,\n    outcome,\n    statusCode: status,\n    responseBody: body,\n    claude_code_session_id: body?.claude_code_session_id || null,\n    claude_code_session_url: body?.claude_code_session_url || null,\n  }\n}];"
      },
