        "jsCode": "// 429 path: append to deferred_fires static data for the drainer workflow to pick up tomorrow.\nconst input = $input.first().json;\nconst staticData = $getWorkflowStaticData('global');\nstaticData.deferred_fires = staticData.deferred_fires || [];\n\nconst entry = {\n  issueId: input.issueId,\n  issueIdentifier: input.issueIdentifier,\n  issueTitle: input.issueTitle,\n  issueDescription: input.issueDescription,\n  issueUrl: input.issueUrl,\n  typeLabel: input.typeLabel,\n  appLabel: input.appLabel,\n  allLabels: input.allLabels,\n  routineName: input.routineName,\n  routineUrl: input.routineUrl,\n  routineToken: input.routineToken,\n  firePayloadText: input.firePayloadText,\n  deferredAt: Date.now(),\n};\nstaticData.deferred_fires.push(entry);\n\nreturn [{ json: { ...input, deferredQueueSize: staticData.deferred_fires.length } }];"
      },
