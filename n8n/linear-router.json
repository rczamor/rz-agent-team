    {
      "parameters": {
        "jsCode": "// POST /api/companies/:id/labels returns 201 with { id, name, color, ... }.\n// Re-attach the ticket fields (which the HTTP node's output replaces with the response body)\n// and hand off the new label UUID to `Build Paperclip payload`.\nconst ticket = $('Resolve linear label').item.json;\nconst resp = $input.first().json;\nconst newId = resp?.id || resp?.data?.id;\nif (!newId) {\n  throw new Error(`Create linear label returned no id. Response: ${JSON.stringify(resp).slice(0, 300)}`);\n}\nreturn [{\n  json: {\n    ...ticket,\n    linearLabelId: newId,\n    needsLabelCreate: false,\n  }\n}];"
      },
      "id": "capture-new-label-id",
      "name": "Capture new label ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1960,
        660
