    {
      "parameters": {
        "jsCode": "// Find-or-create the `linear:{identifier}` label in Paperclip.\n// Paperclip's createIssueSchema has no `linear_ticket_id` field (extra fields are silently\n// dropped), so we persist the Linear ticket -> Paperclip issue link via a label instead.\n// The reconciler can then filter issues by this label's UUID (Paperclip supports ?labelId=<uuid>).\nconst input = $('Dedup + Parse').item.json;\nconst body = $input.first().json;\nconst labels = Array.isArray(body) ? body : (body?.labels || body?.data || []);\nconst target = `linear:${input.issueIdentifier}`;\nconst match = Array.isArray(labels) ? labels.find(l => l && l.name === target) : null;\nif (match && match.id) {\n  return [{\n    json: {\n      ...input,\n      linearLabelId: match.id,\n      needsLabelCreate: false,\n    }\n  }];\n}\n// Color is required by createIssueLabelSchema (6-digit hex). Use Linear's brand purple.\nreturn [{\n  json: {\n    ...input,\n    linearLabelId: null,\n    needsLabelCreate: true,\n    labelCreatePayload: { name: target, color: '#5E6AD2' },\n  }\n}];"
      },
