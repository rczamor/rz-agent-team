# Hostinger VPS (delightful-crystal) connection
HOSTINGER_HOST=                  # e.g. 123.45.67.89  or  delightful-crystal.hostingerps.com
HOSTINGER_PORT=22                # default 22, change if Hostinger uses a custom port
HOSTINGER_USER=root              # usually root on a fresh Hostinger VPS
HOSTINGER_SSH_KEY=~/.ssh/hostinger_vps   # path to private key
# Passphrase is loaded into ssh-agent; do NOT store in plaintext.
# connect.sh will prompt once per session and cache it via ssh-add.
