# ==============================================================================
# agent-team :: .env.example
# ------------------------------------------------------------------------------
# Copy to `.env` on the VPS (same directory as docker-compose.yml) and fill in
# real values. Never commit a populated .env.
#
# Most values can be cribbed from the existing separate projects living under
# /docker/ on the VPS (openclaw-*/, langfuse/, agent-memory/, etc). See the
# README for the exact grep commands.
# ==============================================================================

# ------------------------------------------------------------------------------
# Public ingress (Traefik)
# ------------------------------------------------------------------------------
# DNS apex under which sub-services publish; e.g. "agent-team.example.com"
# will produce paperclip.agent-team.example.com, langfuse.agent-team.example.com, db.agent-team.example.com
PUBLIC_DOMAIN=agent-team.example.com
# Contact address on Let's Encrypt cert requests; expiry alerts land here
LETSENCRYPT_EMAIL=ops@example.com

# ------------------------------------------------------------------------------
# LLM access (shared by all 11 openclaw instances)
# ------------------------------------------------------------------------------
# Anthropic API key used for Opus primaries + escalation on workhorse roles
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
# Ollama Cloud API key (workhorse generations go here, NOT to local ollama)
OLLAMA_API_KEY=REPLACE-ME
# Ollama endpoint -- cloud by default; override to self-hosted if desired
OLLAMA_HOST=https://ollama.com

# ------------------------------------------------------------------------------
# Langfuse (observability) -- shared credentials consumed by openclaw-*
# ------------------------------------------------------------------------------
# Public key the agents send to identify project traces (pk-lf-...)
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE-ME
# Secret key paired with the above (sk-lf-...)
LANGFUSE_SECRET_KEY=sk-lf-REPLACE-ME
# Internal hostname agents POST traces to; keep the service name inside compose
LANGFUSE_HOST=http://langfuse-web:3000

# ------------------------------------------------------------------------------
# Langfuse infra secrets
# ------------------------------------------------------------------------------
# Postgres password for the langfuse app DB user
LANGFUSE_POSTGRES_PASSWORD=REPLACE-ME
# NextAuth session signing secret (32+ random chars)
LANGFUSE_NEXTAUTH_SECRET=REPLACE-ME
# Salt for hashed API keys stored at rest (32+ random chars)
LANGFUSE_SALT=REPLACE-ME
# 64-char hex (32 bytes) -- encrypts sensitive fields in the DB
LANGFUSE_ENCRYPTION_KEY=REPLACE-ME
# ClickHouse user (default "clickhouse" is fine)
LANGFUSE_CLICKHOUSE_USER=clickhouse
# ClickHouse password; separate from postgres password
LANGFUSE_CLICKHOUSE_PASSWORD=REPLACE-ME
# MinIO admin user (default "minio" is fine)
LANGFUSE_MINIO_ROOT_USER=minio
# MinIO admin password
LANGFUSE_MINIO_ROOT_PASSWORD=REPLACE-ME

# ------------------------------------------------------------------------------
# Agent memory (shared postgres for agent long-term state)
# ------------------------------------------------------------------------------
# DB user for the agent_memory database
AGENT_MEMORY_USER=agent_memory
# Password for the above user
AGENT_MEMORY_PASSWORD=REPLACE-ME
# Logical DB name
AGENT_MEMORY_DB=agent_memory
# Full DSN handed to every openclaw instance. Host is the compose service name
AGENT_MEMORY_DSN=postgresql://agent_memory:REPLACE-ME@agent-memory:5432/agent_memory

# ------------------------------------------------------------------------------
# Paperclip
# ------------------------------------------------------------------------------
# Shared secret paperclip presents when calling Hostinger platform APIs
PAPERCLIP_TOKEN=REPLACE-ME

# ------------------------------------------------------------------------------
# Per-role Slack bot tokens (one app per role so audit trails stay clean)
# ------------------------------------------------------------------------------
# Conductor Slack bot token (xoxb-...)
SLACK_BOT_TOKEN_CONDUCTOR=xoxb-REPLACE-ME
# PM Slack bot token
SLACK_BOT_TOKEN_PM=xoxb-REPLACE-ME
# Researcher Slack bot token
SLACK_BOT_TOKEN_RESEARCHER=xoxb-REPLACE-ME
# Designer Slack bot token
SLACK_BOT_TOKEN_DESIGNER=xoxb-REPLACE-ME
# Backend engineer Slack bot token
SLACK_BOT_TOKEN_BACKEND_ENG=xoxb-REPLACE-ME
# Data engineer Slack bot token
SLACK_BOT_TOKEN_DATA_ENG=xoxb-REPLACE-ME
# AI engineer Slack bot token
SLACK_BOT_TOKEN_AI_ENG=xoxb-REPLACE-ME
# UI engineer Slack bot token
SLACK_BOT_TOKEN_UI_ENG=xoxb-REPLACE-ME
# QA engineer Slack bot token
SLACK_BOT_TOKEN_QA_ENG=xoxb-REPLACE-ME
# DevOps engineer Slack bot token
SLACK_BOT_TOKEN_DEVOPS_ENG=xoxb-REPLACE-ME
# Tech writer Slack bot token
SLACK_BOT_TOKEN_TECH_WRITER=xoxb-REPLACE-ME
